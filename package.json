{
  "name": "fabiola-gestion-pro",
  "version": "4.0.0",
  "description": "Sistema de gestión de peluquería y estética — Tecno Jump",
  "private": true,
  "scripts": {
    "build": "tailwindcss -i ./styles.css -o ./dist/output.css --content './index.html' --content './app.js' --minify",
    "build:watch": "tailwindcss -i ./styles.css -o ./dist/output.css --content './index.html' --content './app.js' --watch",
    "serve": "npx serve ."
  },
  "devDependencies": {
    "tailwindcss": "^3.4.0"
  },
  "engines": {
    "node": ">=18"
  }
}
